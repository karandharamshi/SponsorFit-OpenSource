# Copy to .env and fill in locally. Never commit .env.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Optional. Users can later add their own sources.
DATABASE_URL=sqlite:///./sponsorfit.db

# Browser automation
SPONSORFIT_BROWSER_HEADLESS=false
SPONSORFIT_NEVER_AUTO_SUBMIT=true

# User defaults
SPONSORFIT_MIN_SALARY_GBP=41700
SPONSORFIT_COUNTRY=United Kingdom
